# ── ComfyUI backend ───────────────────────────────────────────────────────────
COMFYUI_URL=http://127.0.0.1:8188
COMFYUI_TIMEOUT_S=300

# ── Redis / arq ───────────────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379/0

# ── Local storage ─────────────────────────────────────────────────────────────
STORAGE_UPLOADS=./storage/uploads
STORAGE_OUTPUTS=./storage/outputs
STORAGE_MAX_UPLOAD_MB=20

# ── HTTP server ───────────────────────────────────────────────────────────────
# Leave API_TOKEN empty to disable auth
API_TOKEN=changeme
HOST=0.0.0.0
PORT=8000

# ── Worker ────────────────────────────────────────────────────────────────────
# Do not change — 1 GPU = 1 inference at a time
WORKER_CONCURRENCY_GPU=1

# ── Logging ───────────────────────────────────────────────────────────────────
# LOG_FORMAT: console | json
LOG_LEVEL=INFO
LOG_FORMAT=console

# ── Video generation ──────────────────────────────────────────────────────────
# Timeout in seconds for video jobs (much longer than image ops)
VIDEO_TIMEOUT_S=900

# ── Observability ─────────────────────────────────────────────────────────────
# Leave empty to disable Sentry
SENTRY_DSN=

# ── Model registry (optional) ─────────────────────────────────────────────────
# Set to ComfyUI models directory to warn at startup about missing models.
# Leave commented out to skip the check.
# COMFYUI_MODELS_DIR=/home/user/ComfyUI/models
