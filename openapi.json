          },
          "format": {
            "$ref": "#/components/schemas/ImageFormat",
            "default": "webp"
          },
          "quality": {
            "type": "string",
            "title": "Quality",
            "default": "high"
          },
          "max_width": {
            "anyOf": [
              {
                "type": "integer"
              },
              {
                "type": "null"
              }
            ],
            "title": "Max Width"
          }
        },
        "type": "object",
        "required": [
